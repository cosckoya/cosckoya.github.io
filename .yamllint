---
# yamllint configuration for MkDocs projects
extends: default

rules:
  # More relaxed line length for documentation configs
  line-length:
    max: 120
    level: warning

  # Allow files without document start marker
  document-start:
    present: false

  # Allow common truthy values (on/off, yes/no, true/false)
  truthy:
    allowed-values: ['true', 'false', 'yes', 'no', 'on', 'off']
    check-keys: false

  # Comments formatting
  comments:
    min-spaces-from-content: 1
    require-starting-space: true
    ignore-shebangs: true
    level: warning

  # Indentation - 2 spaces is standard for YAML
  indentation:
    spaces: 2
    indent-sequences: true
    check-multi-line-strings: false
