[codespell]
# Codespell configuration for technical documentation

# Directories to skip
skip = venv,site,test,node_modules,.git,*.pyc,__pycache__

# Technical terms and acronyms to ignore
ignore-words-list = AKS,EKS,GKE,aks,eks,gke,nd,crate,connexion,som,ser,te,ue,ba

# File patterns to check
check-filenames =
check-hidden =

# Quiet mode - only show errors
quiet-level = 2
