# .claudeignore - Files and directories to exclude from Claude Code context
# Similar to .gitignore syntax

# Build artifacts and caches
site/
.cache/
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Virtual environments
venv/
env/
ENV/
.venv/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/
*.out

# Dependencies and lock files
node_modules/
package-lock.json
yarn.lock
Pipfile.lock
poetry.lock

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.backup

# Git internals
.git/
.gitignore

# Documentation build artifacts
.doctrees/
_build/
_static/
_templates/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# OS files
Thumbs.db
desktop.ini

# Large media files (images, videos)
*.jpg
*.jpeg
*.png
*.gif
*.svg
*.ico
*.mp4
*.webm
*.avi
*.mov

# Minified files
*.min.js
*.min.css
*.min.html

# Lock files
*.lock

# Database files
*.db
*.sqlite
*.sqlite3

# Compiled files
*.so
*.dylib
*.dll
*.exe

# Archives
*.zip
*.tar
*.tar.gz
*.rar
*.7z
