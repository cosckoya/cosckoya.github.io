{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "skills": {
    "paths": ["/home/cosckoya/.agentic/skills"]
  },
  "agent": {
    "mcdoc": {
      "description": "Documentation Publisher — creates, maintains, and publishes cosckoya.github.io",
      "mode": "subagent",
      "color": "#00BFA5"
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      ".env*": "deny",
      "secrets/**": "deny",
      "venv/**": "deny",
      "site/**": "deny",
      ".cache/**": "deny"
    },
    "bash": {
      "make *": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git restore *": "allow",
      "git reset *": "allow",
      "git rm *": "allow",
      "gh *": "allow",
      "pre-commit *": "allow",
      "python3 *": "allow",
      "pip *": "allow",
      "ls *": "allow",
      "find *": "allow",
      "tree *": "allow",
      "pwd": "allow",
      "which *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "source venv/*": "allow",
      "mdformat *": "allow",
      "codespell *": "allow",
      "ruff *": "allow",
      "zensical *": "allow",
      "git push *": "allow",
      "git checkout *": "allow",
      "git branch *": "allow",
      "git merge *": "allow",
      "rm -rf *": "deny",
      "curl *": "deny",
      "wget *": "deny",
      "git push --force *": "deny",
      "git reset --hard *": "deny",
      "*": "ask"
    }
  }
}
