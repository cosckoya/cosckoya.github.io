# yamllint configuration
# Balanced rules for documentation projects
extends: default

rules:
  # Disable document-start requirement (optional for MkDocs configs)
  document-start: disable

  # Allow flexible line lengths for documentation
  line-length:
    max: 120
    allow-non-breakable-words: true
    allow-non-breakable-inline-mappings: true

  # Allow both True/true and yes/no
  truthy:
    allowed-values: ['true', 'false', 'True', 'False', 'yes', 'no']
    check-keys: false

  # Relax comment indentation (MkDocs configs have various styles)
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable

  # Standard settings
  indentation:
    spaces: 2
    indent-sequences: true

  # Allow empty values (common in MkDocs configs)
  empty-values:
    forbid-in-block-mappings: false
    forbid-in-flow-mappings: false
